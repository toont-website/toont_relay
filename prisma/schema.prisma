generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model MessageLog {
  id             String   @id @default(cuid())
  direction      String   // "inbound" | "outbound"
  phoneNumber    String   // E.164
  message        String   @db.Text
  status         String   // "sent" | "delivered" | "failed" | "received"
  slackActionId  String?  @unique // 중복 전송 방지
  slackMessageTs String?  // 슬랙 메시지 ts
  slackThreadTs  String?  // 스레드 부모 ts
  slackUserId    String?  // 발신 담당자 Slack ID
  createdAt      DateTime @default(now())

  @@index([phoneNumber])
  @@index([direction])
  @@index([createdAt])
  @@index([phoneNumber, slackThreadTs, createdAt])
}

model PartnerChatConversation {
  id               String   @id @default(cuid())
  partnerType      String
  company          String
  identifier       String
  contactName      String
  email            String
  phone            String
  inquiryType      String
  status           String   @default("open")
  visitorSessionId String?
  slackChannelId   String?
  slackMessageTs   String?
  slackThreadTs    String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  messages PartnerChatMessage[]

  @@index([status])
  @@index([visitorSessionId])
  @@index([createdAt])
}

model PartnerChatMessage {
  id             String   @id @default(cuid())
  conversationId String
  direction      String   // "customer" | "agent" | "system"
  message        String   @db.Text
  slackActionId  String?  @unique
  slackMessageTs String?
  slackUserId    String?
  createdAt      DateTime @default(now())

  conversation PartnerChatConversation @relation(fields: [conversationId], references: [id])

  @@index([conversationId, createdAt])
  @@index([direction])
}

model HealthCheckLog {
  id             String    @id @default(cuid())
  mysqlStatus    String    // "ok" | "error"
  gatewayStatus  String    // "ok" | "error"
  deviceStatus   String    // "ok" | "stale" | "error"
  deviceLastSeen DateTime?
  alertSent      Boolean   @default(false)
  createdAt      DateTime  @default(now())

  @@index([createdAt])
}

model DeadlineAlertLog {
  id        String   @id @default(cuid())
  orderId   String
  stageId   String
  alertDate String   // YYYY-MM-DD (KST)
  sentAt    DateTime @default(now())

  @@unique([orderId, stageId, alertDate])
  @@index([alertDate])
}

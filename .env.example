# Slack
SLACK_BOT_TOKEN=xoxb-your-bot-token-here
SLACK_SIGNING_SECRET=your-signing-secret-here
SLACK_CHANNEL_CS_SMS=C0000000000
SLACK_CHANNEL_ALERT=C0000000000
SLACK_CHANNEL_PARTNER_CHAT=C0000000000
PARTNER_CHAT_WEBHOOK_SECRET=replace-with-long-random-secret

# SMS Gateway
# 폰 앱 연결 후 표시되는 크레덴셜 입력
SMS_GATEWAY_URL=http://sms-backend:3080
SMS_GATEWAY_USERNAME=your-username-here
SMS_GATEWAY_PASSWORD=your-password-here
# 웹훅 서명 검증용 시크릿 (폰 앱 Settings → Webhooks → Signing Key)
SMS_GATEWAY_WEBHOOK_SECRET=your-webhook-secret-here
# 폰 앱 연결용 프라이빗 토큰 (직접 생성: openssl rand -hex 32)
ASG_GATEWAY_PRIVATE_TOKEN=your-private-token-here

# Database
DATABASE_URL=mysql://toont:toont_password@mysql:3306/toont_relay
MYSQL_ROOT_PASSWORD=your-mysql-root-password-here

# App
NODE_ENV=production
APP_URL=https://your-domain.com

# CS Tool (TOONT-CS)
CS_TOOL_API_URL=https://cs.toont.co.kr/api/v1
CS_TOOL_API_KEY=your-cs-tool-api-key-here
CS_TOOL_WEBHOOK_SECRET=your-cs-tool-webhook-secret-here
SLACK_CHANNEL_ORDER=C0000000000
SLACK_CHANNEL_INVENTORY=C0000000000
SLACK_CHANNEL_OPERATION=C0000000000

# Health Check Monitoring
# cron job 인증용 시크릿 (직접 생성: openssl rand -hex 32)
CRON_SECRET=your-cron-secret-here
# 기기 연결 stale 판단 임계값 (분, 기본값 30)
HEALTH_CHECK_DEVICE_THRESHOLD_MINUTES=30
